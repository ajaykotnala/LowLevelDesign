{
  "name": "lld-design-patterns",
  "version": "0.1.0",
  "private": true,
  "author": "Ajay kotnale",
  "license": "MIT",
  "description": "Design Patterns in TypeScript",
  "keywords": [
    "design-patterns",
    "typescript",
    "javascript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ajaykotnale/lld-design-patterns"
  },
  "bugs": {
    "url": "https://github.com/ajaykotnale/lld-design-patterns/issues"
  },
  "homepage": "https://github.com/ajaykotnale/lld-design-patterns#readme",
  "dependencies": {
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "packageManager": "npm@8.19.2", 
  "scripts": {
    "basicfactory": "npx -y ts-node basic-factory-pattern.ts",
    "advancefactory": "npx -y ts-node advace-factory-pattern.ts",
    "builder": "npx -y ts-node builder-pattern.ts",
    "prototype": "npx -y ts-node prototype-pattern.ts",
    "run": "npm run run:factory"
   
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  }
}
